NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Prefer MONGODB_URI. Railway/add-ons may expose one of the fallback names below.
MONGO_URI=
MONGODB_URI=
MONGODB_URL=
MONGO_URL=
DATABASE_URL=

# Data source selector: memory | mongo
DATA_SOURCE=memory

# Authentication (required for user molecule persistence)
AUTH_REQUIRED=false
AUTH_SERVICE_URL=
AUTH_VALIDATE_PATH=/validate-token
AUTH_PROFILE_PATH=/profile

# Product-admin bootstrap ids (auth user ids)
ADMIN_BOOTSTRAP_USER_IDS=

# Optional future bridge to clean-auth for revoking third-party sessions
AUTH_REVOKE_USER_SESSIONS_PATH=

# Comma-separated origins allowed by CORS (no trailing slash)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Mobile/LAN example:
# CORS_ORIGINS=http://192.168.3.5:3000,http://localhost:3000,http://127.0.0.1:3000
