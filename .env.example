NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Prefer MONGODB_URI. Railway/add-ons may expose one of the fallback names below.
MONGO_URI=
MONGODB_URI=
MONGODB_URL=
MONGO_URL=
DATABASE_URL=

# Data source selector: memory | mongo
DATA_SOURCE=memory

# Authentication (optional for now; useful to plug an external auth microservice later)
AUTH_REQUIRED=false
AUTH_SERVICE_URL=
AUTH_VALIDATE_PATH=/validate-token
