NODE_ENV=production
HOST=0.0.0.0
# Railway injects PORT automatically
PORT=

# Data source
DATA_SOURCE=mongo
MONGO_URI=<FILL_WITH_MONGODB_URI>

# Auth integration
AUTH_REQUIRED=true
# Option A (recommended simple): use auth public domain
AUTH_SERVICE_URL=https://<FILL_AUTH_PUBLIC_DOMAIN>
# Option B (private networking): http://<private-host>:<port>
# AUTH_SERVICE_URL=http://<AUTH_PRIVATE_DOMAIN>:<AUTH_PORT>
AUTH_INTERNAL_SERVICE_TOKEN=<FILL_WITH_SHARED_INTERNAL_SECRET>
AUTH_VALIDATE_PATH=/validate-token
AUTH_PROFILE_PATH=/profile

# Product-admin bootstrap ids (auth user ids)
ADMIN_BOOTSTRAP_USER_IDS=<FILL_WITH_ADMIN_USER_ID>

# Optional bridge to clean-auth for revoking refresh sessions
# AUTH_REVOKE_USER_SESSIONS_PATH=/internal/users/:userId/sessions/revoke

# Browser CORS (comma-separated)
CORS_ORIGINS=https://<FILL_FRONTEND_DOMAIN>
